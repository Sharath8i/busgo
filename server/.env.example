# ── Server Configuration ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/busgo

# ── Security ──────────────────────────────────────────────────────────────────
# Use strong random strings for production
JWT_SECRET=your_super_secret_access_token_key_123!
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_456!

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
# Get these from Razorpay Dashboard (Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Email Service (Nodemailer) ────────────────────────────────────────────────
# For Gmail: Use App Passwords (not your master password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────
# Get these from Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
